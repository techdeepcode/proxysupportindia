# Copy to .env and fill in. All are optional — nothing is injected unless set.
# Do NOT commit real values. These are PUBLIC (client-exposed) by design.

# Google Analytics 4 (gtag)
PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager — live default GTM-N57S3DVZ is set in code (gtm.js container).
# All other tracking (GA4, Ads, Meta Pixel, etc.) is managed INSIDE this GTM container.
# Only set this to OVERRIDE the default container.
PUBLIC_GTM_ID=

# Search engine verification
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=

# Reserved for future tags (wire up in src/components/Analytics.astro):
# PUBLIC_META_PIXEL_ID=
# PUBLIC_LINKEDIN_PARTNER_ID=
# PUBLIC_CLARITY_ID=
# PUBLIC_HOTJAR_ID=
