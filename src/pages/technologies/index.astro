---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import CTASection from '@components/CTASection.astro';
import Schema from '@components/Schema.astro';
import { technologies, techCategories } from '@data/technologies';

const title = 'Technology Proxy Support — AI/ML, DevOps, Java, .NET, Workday, UiPath & More | Proxy Support India';
const description = 'Proxy interview support and proxy job support across every major 2026 technology — AI/ML, GenAI, DevOps, cloud, Java, .NET, React, Workday, UiPath, Salesforce, SAP and more.';
const crumbs = [{ label: 'Home', href: '/' }, { label: 'Technologies', href: '/technologies' }];
---
<BaseLayout title={title} description={description} path="/technologies">
  <Schema pageType="CollectionPage" name="Technology Proxy Support" description={description} breadcrumb={crumbs}
    itemList={{ name: 'Technologies', items: technologies.map((t) => ({ name: `${t.name} Proxy Interview Support`, url: `/${t.slug}-proxy-interview-support` })) }} />
  <PageHero eyebrow="Technology coverage · 2026 demand order" h1="Technology-Specific Proxy Interview & Job Support" intro="Pick your stack. Every technology below has stack-matched experts for both proxy interview support and proxy job support, across USA and global markets." breadcrumb={crumbs} />
  <section class="wrap section">
    {techCategories.map((cat) => (
      <div style="margin-top:2rem;">
        <h2 style="color:rgb(var(--primary)); font-size:1.3rem;">{cat}</h2>
        <div class="related" style="margin-top:.8rem;">
          {technologies.filter((t) => t.category === cat).map((t) => (
            <a href={`/${t.slug}-proxy-interview-support`}>{t.name} — {t.blurb}</a>
          ))}
        </div>
      </div>
    ))}
  </section>
  <CTASection />
</BaseLayout>
