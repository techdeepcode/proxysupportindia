---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import CTASection from '@components/CTASection.astro';
import Schema from '@components/Schema.astro';
import { howToGetTopics, howToGetMarkets } from '@data/howToGet';
import { countryBySlug } from '@data/countries';

const title = 'How to Get IT Jobs in 2026 — By Technology & Country | Proxy Support India';
const description = 'Guides on how to get AI/ML, GenAI, Cloud, DevOps, Data, Cybersecurity and higher-paying IT jobs in USA, Canada, UK, Europe, Australia, Singapore, Japan, New Zealand, UAE and India.';
const crumbs = [{ label: 'Home', href: '/' }, { label: 'How to Get IT Jobs', href: '/how-to-get-it-jobs' }];
const markets = howToGetMarkets.map((m) => countryBySlug(m)!);
---
<BaseLayout title={title} description={description} path="/how-to-get-it-jobs" keywords={['how to get it jobs', 'how to get ai jobs', 'how to get cloud jobs', 'higher paying it roles', 'proxy support india']}>
  <Schema pageType="CollectionPage" name="How to Get IT Jobs in 2026" description={description} breadcrumb={crumbs}
    itemList={{ name: 'How-to-get guides', items: howToGetTopics.map((t) => ({ name: `How to Get ${t.label} Jobs`, url: `/how-to-get-${t.slug}` })) }} />
  <PageHero
    eyebrow="Career guides · 2026"
    h1="How to Get IT Jobs in 2026 — by Technology & Country"
    intro="Practical, funnel-connected guides: build the right profile, attract more recruiter calls, prepare for the interviews with proxy interview support, and deliver with proxy job support — for the hottest technologies across USA and global markets."
    breadcrumb={crumbs}
  />
  <section class="wrap section">
    {howToGetTopics.map((t) => (
      <div style="margin-top:1.8rem;">
        <h2 style="color:rgb(var(--primary)); font-size:1.25rem;"><a href={`/how-to-get-${t.slug}`}>How to Get {t.label} Jobs →</a></h2>
        <div class="related" style="margin-top:.7rem;">
          {markets.map((c) => <a href={`/how-to-get-${t.slug}-in-${c.slug}`}>{t.label} jobs in {c.name}</a>)}
        </div>
      </div>
    ))}
  </section>
  <CTASection heading="Aim for the role you want" text="Tell us your target technology and market on WhatsApp. We’ll map the path — profile, recruiter calls, interviews and job support — to support you along the way." />
</BaseLayout>
