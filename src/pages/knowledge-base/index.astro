---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import CTASection from '@components/CTASection.astro';
import Schema from '@components/Schema.astro';
import { knowledgeBase, kbCategories } from '@data/knowledgeBase';

const title = 'Knowledge Base — Proxy Interview & Job Support Explained | Proxy Support India';
const description = 'Clear answers about proxy interview support, proxy job support, profile engineering, marketing, managing, recruiter calls and India-to-global support.';
const crumbs = [{ label: 'Home', href: '/' }, { label: 'Knowledge Base', href: '/knowledge-base' }];
---
<BaseLayout title={title} description={description} path="/knowledge-base">
  <Schema pageType="CollectionPage" name="Knowledge Base — Proxy Support India" description={description} breadcrumb={crumbs}
    itemList={{ name: 'Knowledge Base', items: knowledgeBase.map((k) => ({ name: k.title, url: `/knowledge-base/${k.slug}` })) }} />
  <PageHero eyebrow="Knowledge base" h1="Proxy Support, Explained" intro="Straight answers to the questions candidates actually ask — what each service is, how it works, and what it costs." breadcrumb={crumbs} />
  <section class="wrap section">
    {kbCategories.map((cat) => (
      <div style="margin-top:1.8rem;">
        <h2 style="color:rgb(var(--primary)); font-size:1.25rem;">{cat}</h2>
        <div class="related" style="margin-top:.7rem;">
          {knowledgeBase.filter((k) => k.category === cat).map((k) => <a href={`/knowledge-base/${k.slug}`}>{k.title}</a>)}
        </div>
      </div>
    ))}
  </section>
  <CTASection />
</BaseLayout>
