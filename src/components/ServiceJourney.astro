---
import { waTalk } from '@data/site';
import WhatsAppIcon from './WhatsAppIcon.astro';
const stages = [
  { n: '01', h: 'Engineer your profile', p: 'ATS-ready CV, LinkedIn and JD-wise positioning for your target market.', href: '/profile-engineering' },
  { n: '02', h: 'Market for calls', p: 'Recruiter outreach, submissions and pipeline management until interview calls flow.', href: '/profile-marketing' },
  { n: '03', h: 'Clear the interview', p: 'JD-based, round-wise proxy interview support through coding, system design and client rounds.', href: '/proxy-interview-support' },
  { n: '04', h: 'Land the offer', p: 'Offer and joining support — negotiation guidance and preparation for a smooth start.', href: '/end-to-end-it-career-proxy-support' },
  { n: '05', h: 'Deliver the job', p: 'Real-time proxy job support with daily project work so you stay job-ready and stable.', href: '/proxy-job-support' },
];
---
<section class="section" id="journey">
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">End-to-end support flow</p>
      <h2>One journey — from profile to interview to a stable job</h2>
      <p>Every service sits on a single path, so you always know the next step. Tap any stage to go to that service.</p>
    </div>
    <ol class="rail">
      {stages.map((s) => (
        <li class="stage">
          <span class="stage-num">{s.n}</span>
          <h3><a href={s.href} class="stage-title">{s.h}</a></h3>
          <p>{s.p}</p>
          <a class="stage-link" href={s.href}>Open →</a>
        </li>
      ))}
    </ol>
    <div class="cta-row" style="margin-top:2.2rem">
      <a class="btn btn-wa" href={waTalk} target="_blank" rel="noopener" data-cta="whatsapp-click"><WhatsAppIcon /> Talk on WhatsApp</a>
      <a class="btn btn-line" href="/end-to-end-it-career-proxy-support">See end-to-end support →</a>
    </div>
  </div>
</section>
