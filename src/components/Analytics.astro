---
// Analytics & tag injection — all env-driven. Nothing renders unless
// the corresponding PUBLIC_* env var is set (never hardcode fake IDs).
//
// Configure in a .env file (see .env.example):
//   PUBLIC_GA_MEASUREMENT_ID   -> Google Analytics 4 (gtag)
//   PUBLIC_GTM_ID              -> Google Tag Manager
//
// Other tags — add your IDs where marked and uncomment:
//   • Google Ads conversion tracking  (gtag 'event' conversion)
//   • Meta Pixel                      (fbq)
//   • LinkedIn Insight Tag            (_linkedin_partner_id)
//   • Microsoft Clarity               (clarity)
//   • Hotjar                          (hj)
// Google Analytics 4 (gtag.js) — OFF unless PUBLIC_GA_MEASUREMENT_ID is set.
// We track via the GTM container below, not a standalone gtag.
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
// Google Tag Manager container — loaded via gtm.js. Live default GTM-N57S3DVZ;
// override with PUBLIC_GTM_ID.
const GTM_ID = import.meta.env.PUBLIC_GTM_ID || 'GTM-N57S3DVZ';
---
{GA_ID && (
  <>
    <script async is:inline src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_ID);
      // WhatsApp / CTA click tracking — fires GA event for any [data-cta] element.
      document.addEventListener('click', function (e) {
        const el = e.target && e.target.closest ? e.target.closest('[data-cta]') : null;
        if (el) gtag('event', 'cta_click', { cta_id: el.getAttribute('data-cta') });
      });
    </script>
  </>
)}

{GTM_ID && (
  <script is:inline define:vars={{ GTM_ID }}>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
    var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
    j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer',GTM_ID);
  </script>
)}

<!-- Meta Pixel: add PUBLIC_META_PIXEL_ID and enable here -->
<!-- LinkedIn Insight Tag: add PUBLIC_LINKEDIN_PARTNER_ID and enable here -->
<!-- Microsoft Clarity: add PUBLIC_CLARITY_ID and enable here -->
<!-- Hotjar: add PUBLIC_HOTJAR_ID and enable here -->
