---
{links.length > 0 && (
  <div class={`social-links social-${variant} ${klass}`.trim()}>
    {links.map((s) => (
      <a
        href={s.url}
        class={`social-link social-${s.key}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={s.label}
        title={s.label}
        data-cta={`social-${s.key}`}
      >
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
          <path fill="currentColor" d={icons[s.key]} />
        </svg>
      </a>
    ))}
  </div>
)}
